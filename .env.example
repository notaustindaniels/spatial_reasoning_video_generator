# =============================================================================
# Depthkit Multi-Agent Harness — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# -----------------------------------------------------------------------------
# REQUIRED: Claude Code OAuth Token
# Obtain from: https://console.anthropic.com/
# Used by the Claude Code SDK for all agent sessions (Explorer, Reviewer, etc.)
# -----------------------------------------------------------------------------
CLAUDE_CODE_OAUTH_TOKEN=your-oauth-token-here

# -----------------------------------------------------------------------------
# OPTIONAL: Google Gemini API Key
# Used by the Director Agent for visual tuning (multimodal video review).
# Only required if you run director sessions. Skipped otherwise.
# Obtain from: https://aistudio.google.com/apikey
# -----------------------------------------------------------------------------
GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# Model Configuration
# -----------------------------------------------------------------------------
# Claude model for Explorer/Reviewer/Integrator/Synthesizer sessions
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# Gemini model for Director Agent sessions
GEMINI_MODEL=gemini-2.5-pro

# -----------------------------------------------------------------------------
# Harness Behavior
# -----------------------------------------------------------------------------
# Maximum turns per agent session (higher = longer sessions, more context usage)
MAX_TURNS=1000

# Seconds to wait between sessions before auto-continuing
AUTO_CONTINUE_DELAY=3

# How many explorer completions between integrator runs
INTEGRATOR_CADENCE=15

# Default project directory (relative paths go under generations/)
DEFAULT_PROJECT_DIR=depthkit

# -----------------------------------------------------------------------------
# Director Agent HITL Configuration
# -----------------------------------------------------------------------------
# When true, director critiques pause for human approval (required by spec).
# Set to false ONLY for dry-run testing of the director pipeline.
HITL_ENABLED=true
