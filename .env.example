# ============================================================
# Depthkit Multi-Agent Harness — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.

# REQUIRED: Claude Code OAuth token for agent sessions
CLAUDE_CODE_OAUTH_TOKEN=

# Agent model selection
CLAUDE_MODEL=claude-opus-4-6

# Project directory (relative paths placed under generations/)
PROJECT_DIR=./depthkit

# Session limits
MAX_ITERATIONS=          # Leave empty for unlimited

# Deliberation settings — agents converse until they converge.
# Safety caps prevent infinite loops but are NOT targets.
INIT_SAFETY_CAP=20       # Max rounds for architect A/B decomposition deliberation
EXPLORE_SAFETY_CAP=12    # Max rounds for spec author/challenger deliberation per objective

# Orchestrator behavior
AUTO_CONTINUE_DELAY=3    # Seconds between sessions
INTEGRATOR_CADENCE=15    # Run integrator every N explorer completions

# Peak-hour scheduling
# Pauses during Anthropic peak pricing (8 AM – 2 PM ET, weekdays).
# Set to true to run regardless of time.
IGNORE_PEAK_HOURS=false

# Git push configuration
# The orchestrator pushes after each deliberation completes.
# Uses Claude Code's SSH key (see .ssh/config).
GIT_PUSH_REMOTE=claude   # git remote name (must be configured in the project repo)
GIT_PUSH_BRANCH=master   # branch to push

# Director Agent (Gemini) — for visual tuning phases only
# Leave empty to skip visual tuning entirely
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-pro

# Logging
LOG_LEVEL=INFO
LOG_DIR=./logs
